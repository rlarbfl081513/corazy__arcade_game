# Server Configuration
SERVER_PORT=8080

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=coa_database
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT Configuration
# IMPORTANT: Use a strong secret key (minimum 256 bits / 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-minimum-32-characters-required-here

# Microservice URLs
# Auth Server
AUTH_SERVER_URL=http://localhost:8081

# Ranking Server
RANKING_SERVER_URL=http://localhost:8082

# Dictation Server
DICTATION_SERVER_URL=http://localhost:8083

# Chat Server
CHAT_SERVER_URL=http://localhost:8084

# Algorithm Server
ALGORITHM_SERVER_URL=http://localhost:8085