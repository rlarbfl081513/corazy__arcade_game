# 프로젝트 설정
PROJECT_NAME=COA Compile Server
VERSION=1.0.0

# API 설정
API_V1_STR=/api/v1

# CORS 설정 (쉼표로 구분)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5500

# Database 설정 (MySQL)
# MySQL: mysql://user:password@localhost:3306/dbname
# PostgreSQL: postgresql://user:password@localhost:5432/dbname
# SQLite: sqlite:///./database.db
DATABASE_URL=mysql://root:password@localhost:3306/compile_server
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis 설정
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# RabbitMQ 설정
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE_NAME=compile_queue

# AWS S3 설정
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=your_bucket_name
